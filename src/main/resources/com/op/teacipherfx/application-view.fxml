<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" prefWidth="600.0" stylesheets="@../../../style/style.css" styleClass="main-container"
      xmlns:fx="http://javafx.com/fxml" fx:controller="com.op.teacipherfx.CipherController">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="TEA Cipher Engine" styleClass="title-label"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="?" onAction="#onUserManualClick" styleClass="help-button"/>
    </HBox>

    <VBox spacing="12.0" styleClass="card">
        <Label text="КЕРУВАННЯ КЛЮЧЕМ" styleClass="section-header"/>
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <TextField fx:id="passwordField" promptText="Введіть ключ або завантажте .op..."
                       HBox.hgrow="ALWAYS" styleClass="modern-input"/>
            <Button text="Завантажити" onAction="#onLoadPasswordFileClick" styleClass="secondary-button"/>
            <Button text="Генерувати" onAction="#onGeneratePasswordClick" styleClass="secondary-button"/>
        </HBox>
        <ProgressBar fx:id="strengthBar" progress="0.0" maxWidth="Infinity" styleClass="strength-bar"/>
        <Label fx:id="passwordStrengthLabel" text="Статус ключа: очікування..." styleClass="hint-label"/>
    </VBox>

    <VBox spacing="12.0" styleClass="card" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT">
            <Label text="ВХІДНІ ДАНІ" styleClass="section-header"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Завантажити .txt" onAction="#onLoadTextFileClick" styleClass="text-link-button"/>
        </HBox>
        <TextArea fx:id="inputTextArea" promptText="Введіть текст для обробки тут..."
                  wrapText="true" VBox.vgrow="ALWAYS" styleClass="modern-textarea"/>
    </VBox>

    <HBox alignment="CENTER" spacing="20.0">
        <Button fx:id="encryptButton" text="ЗАШИФРУВАТИ" onAction="#onEncryptClick"
                styleClass="primary-button, encrypt-bg"/>
        <Button fx:id="decryptButton" text="РОЗШИФРУВАТИ" onAction="#onDecryptClick"
                styleClass="primary-button, decrypt-bg"/>
    </HBox>

    <HBox styleClass="status-bar" alignment="CENTER_LEFT">
        <Label fx:id="statusLabel" text="Ready" styleClass="status-text"/>
    </HBox>
</VBox>